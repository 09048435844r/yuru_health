# ==========================================
# YuruHealth production env template (Raspberry Pi)
# ==========================================
# このファイルに実値を入れて運用してください。
# 値の引用符は不要です（空白を含む場合のみ使用）。

# --- Runtime / operations ---
# 推奨: コンテナ時刻を JST に固定
TZ=Asia/Tokyo
# 推奨: Python ログを即時 flush
PYTHONUNBUFFERED=1
# worker 実行間隔（秒）: 900 = 15分
FETCH_INTERVAL_SECONDS=900

# --- Supabase (必須) ---
# 取得元: Supabase Project Settings > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co
# 取得元: Supabase Project Settings > API > anon/public key
SUPABASE_KEY=your_supabase_anon_key

# --- Oura (必須: Oura取得を使う場合) ---
# 取得元: Oura Personal Access Tokens
OURA_PERSONAL_TOKEN=your_oura_personal_token

# --- Gemini (任意: Deep Insightを使う場合) ---
# 取得元: Google AI Studio API key
GEMINI_API_KEY=your_gemini_api_key
# 取得元: プロジェクト既定モデル名（例: gemini-1.5-flash / gemini-3-flash-preview）
GEMINI_MODEL_NAME=gemini-1.5-flash

# --- OpenWeatherMap (任意: 天気取得を使う場合) ---
# 取得元: OpenWeatherMap API keys
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
# 取得元: 観測地点の緯度経度（例: 自宅）
OPENWEATHERMAP_DEFAULT_LAT=35.6762
OPENWEATHERMAP_DEFAULT_LON=139.6503

# --- Withings OAuth (Withings取得で必須) ---
# 取得元: Withings Developer Dashboard
WITHINGS_CLIENT_ID=your_withings_client_id
WITHINGS_CLIENT_SECRET=your_withings_client_secret
# 取得元: Withings App 設定の Callback URL と一致させる
WITHINGS_REDIRECT_URI=https://your-streamlit-domain/callback

# --- Google OAuth / Google Fit (Google Fit取得で必須) ---
# 取得元: Google Cloud Console > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# 取得元: Google OAuth 許可済みリダイレクト URI
GOOGLE_REDIRECT_URI_CLOUD=https://your-streamlit-domain/
GOOGLE_REDIRECT_URI_LOCAL=http://localhost:8501/

# --- SwitchBot (任意: SwitchBot取得を使う場合) ---
# 取得元: SwitchBot Open API
SWITCHBOT_TOKEN=your_switchbot_token
SWITCHBOT_SECRET=your_switchbot_secret
SWITCHBOT_DEVICE_ID=your_switchbot_device_id

# --- 重要メモ ---
# Withings/Google の refresh token は .env ではなく
# Supabase の oauth_tokens テーブルに保存されます。
# 新規環境で oauth_tokens が空の場合、最初に UI で OAuth 再認証してください。
